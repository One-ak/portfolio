Options -Indexes

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com https://unicons.iconscout.com data:; style-src 'self' https://fonts.googleapis.com https://unicons.iconscout.com; script-src 'self'; connect-src 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests"
</IfModule>

<FilesMatch "(^\.|\.py$|\.docx$|\.DS_Store$)">
    Require all denied
</FilesMatch>

RedirectMatch 404 ^/cv_render(/.*)?$
